# Classic CHIP-8 ROMs (common free ROMs)
# We'll generate synthetic ROMs since we don't have ROM files yet.
# Users can drop real .ch8 files into the roms/ directory.

OPCODE_TEMPLATES = [
    # (generator_func_name, weight)
    ("gen_cls", 2),
    ("gen_ret", 2),
    ("gen_jp", 5),
    ("gen_call", 3),
    ("gen_se_vx_nn", 5),
    ("gen_sne_vx_nn", 5),
    ("gen_se_vx_vy", 4),
